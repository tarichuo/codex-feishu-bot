# 飞书应用的 App ID。
# 由你在飞书开放平台创建机器人应用后获得。
FEISHU_CODEX_BOT_FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxxx

# 飞书应用的 App Secret。
# 由你在飞书开放平台创建机器人应用后获得。
FEISHU_CODEX_BOT_FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# 本机 Codex app server 的访问地址。
# 当前实现只要求是一个可访问的 URL，后续 JSON-RPC 客户端会基于它建立连接。
FEISHU_CODEX_BOT_CODEX_SERVER_URL=ws://127.0.0.1:9000

# owner 的飞书 open_id，格式通常为 ou_xxx。
# 当非白名单用户尝试和机器人对话时，机器人会向这个 open_id 发送安全告警。
# 注意：这个值也必须同时出现在 ALLOWED_USER_IDS 中。
# 当前实现虽然会对入站事件里的 user_id / union_id 做兜底读取，但配置项请统一填写 open_id。
# 获取方式参考https://open.feishu.cn/document/faq/trouble-shooting/how-to-obtain-openid
FEISHU_CODEX_BOT_OWNER_USER_ID=ou_xxxxxxxxxxxxxxxxx

# 允许与机器人对话的飞书 open_id 白名单，多个值用英文逗号分隔，格式通常为 ou_xxx。
# 只有这些 open_id 的消息才会进入后续的会话路由和 Codex 调用链路。
# 当前实现虽然会对入站事件里的 user_id / union_id 做兜底读取，但配置项请统一填写 open_id。
FEISHU_CODEX_BOT_ALLOWED_USER_IDS=ou_xxxxxxxxxxxxxxxxx,ou_yyyyyyyyyyyyyyyyy

# 数据目录。
# 默认是仓库根目录下的 var/。
# 如果你希望把数据库、日志和媒体文件放到其他目录，可以修改这里。
FEISHU_CODEX_BOT_DATA_DIR=var

# SQLite 数据库文件路径。
# 默认是 {DATA_DIR}/app.db。
# 如果设置了这个值，会覆盖默认数据库路径。
FEISHU_CODEX_BOT_SQLITE_PATH=var/app.db

# 媒体文件目录。
# 默认是 {DATA_DIR}/media。
# 飞书图片下载到本地后会存放在这里，后续也可用于输出文件中转。
FEISHU_CODEX_BOT_MEDIA_DIR=var/media

# 日志目录。
# 默认是 {DATA_DIR}/logs。
# 结构化日志文件 app.log 会写到这里。
FEISHU_CODEX_BOT_LOGS_DIR=var/logs

# 日志级别。
# 可选值：DEBUG、INFO、WARNING、ERROR、CRITICAL。
# 开发调试时建议先用 DEBUG。
FEISHU_CODEX_BOT_LOG_LEVEL=DEBUG
